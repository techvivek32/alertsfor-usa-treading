# Copy this file to ".env" and fill in your values. The real .env is gitignored.

# Free market data key — get one at https://finnhub.io
FINNHUB_KEY=your_finnhub_key_here
PORT=3000

# ---- Claude (best-trade + smart news) ----
# Two ways to power Claude. Pick ONE:
#
# A) On YOUR PC (free, uses your Claude Max login via the Claude Code CLI):
#    leave ANTHROPIC_API_KEY blank and don't set ENABLE_CLAUDE (defaults on).
#
# B) On a SERVER / VPS (paid, per-token — needs API credits at console.anthropic.com):
#    set ANTHROPIC_API_KEY below. The server then uses the API automatically.
ANTHROPIC_API_KEY=
# Optional model overrides (cheap defaults). Bump BEST to claude-sonnet-4-6 or
# claude-opus-4-8 for stronger best-trade reasoning at higher cost.
CLAUDE_SENTIMENT_MODEL=claude-haiku-4-5
CLAUDE_BEST_MODEL=claude-haiku-4-5
# Set to 1 to FORCE the free CLI even when an API key is present (PC). Set to 0 to disable the CLI.
# ENABLE_CLAUDE=1
