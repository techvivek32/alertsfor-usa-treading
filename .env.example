# Copy this file to ".env" and fill in your values. The real .env is gitignored.
# Get a free Finnhub key at https://finnhub.io
FINNHUB_KEY=your_finnhub_key_here
PORT=3000
# Set to 1 ONLY on a machine where the Claude Code CLI is logged in (your PC).
# On a VPS/cloud leave it 0 (uses keyword sentiment).
ENABLE_CLAUDE=0
